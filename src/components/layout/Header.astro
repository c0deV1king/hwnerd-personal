---
import AboutMe from "../ui/AboutMe.astro";
---

<div class="flex flex-col text-black items-center justify-center mt-5">
  <div class="sm:w-[50%] w-full flex flex-col">
    <div
      class="text-lg sm:text-2xl font-medium sm:font-light self-center sm:self-start"
    >
      &lt; Austin Higgins / &gt;
    </div>
    <div class="flex flex-col sm:flex-row flex-wrap">
      <div class="flex-1 h-36 overflow-hidden">
        <AboutMe />
      </div>
      <!-- Three.js canvas location -->
      <div class="w-36 h-36 self-center sm:self-start bg-black flex-shrink-0">
        <p class="flex justify-center text-white text-sm items-center h-full">
          future portrait
        </p>
      </div>
    </div>
    <div class="w-full bg-black h-0.5 my-4"></div>
  </div>
</div>
