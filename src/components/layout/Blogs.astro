---
import { blogs } from "../../data/blogs";
import BlogBlock from "../ui/BlogBlock.astro";
---

<div class="flex justify-center mt-1 mb-8">
  <div class="flex flex-col p-0 w-[100%] sm:w-[50%]">
    <h2 class="text-2xl font-bold italic self-center sm:self-start">things and stuff</h2>
    <ul class="space-y-4 self-start">
      {
        blogs.map((blog) => (
          <BlogBlock
            title={blog.title}
            date={blog.date}
            slug={blog.slug}
          />
        ))
      }
    </ul>
  </div>
</div>
<div class="w-[50%] bg-black h-0.5 flex self-center"></div>
