---
export interface Props {
  title: string;
  date: string;
  slug: string;
}
const { title, date, slug } = Astro.props;
---

<div class="flex items-start flex-col sm:flex-row gap-4">
  <h3 class="text-xl font-semibold cursor-pointer">
    <a href=`/blog/${slug}`> {title} </a>
  </h3>
  <p class="text-sm text-center">{date}</p>
</div>
